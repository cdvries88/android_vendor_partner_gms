<?xml version="1.0" encoding="utf-8"?>
<exceptions>
    <exception package="com.hmdm.launcher">
        <!-- Camera en Telefoon (Runtime) -->
        <permission name="android.permission.CAMERA" fixed="true" granted="true"/>
        <permission name="android.permission.READ_PHONE_STATE" fixed="true" granted="true"/>
        <permission name="android.permission.CALL_PHONE" fixed="true" granted="true"/>
        
        <!-- Locatie (indien nodig voor MDM tracking) -->
        <permission name="android.permission.ACCESS_FINE_LOCATION" fixed="true" granted="true"/>
        <permission name="android.permission.ACCESS_COARSE_LOCATION" fixed="true" granted="true"/>
        <permission name="android.permission.ACCESS_BACKGROUND_LOCATION" fixed="true" granted="true"/>

        <!-- Opslag -->
        <permission name="android.permission.READ_EXTERNAL_STORAGE" fixed="true" granted="true"/>
        <permission name="android.permission.WRITE_EXTERNAL_STORAGE" fixed="true" granted="true"/>
    </exception>
</exceptions>
